{
  "name": "peru-trip-visualizer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "generate:day-insights:build": "tsc scripts/generateTripPlanDayInsights.ts --outDir .tmp/scripts --module commonjs --target es2022 --moduleResolution node --esModuleInterop --skipLibCheck",
    "generate:day-insights": "npm run generate:day-insights:build --silent && node .tmp/scripts/scripts/generateTripPlanDayInsights.js"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
